## 🗄️ Esquema de Base de Datos

```sql
-- Usuarios del sistema
CREATE TABLE users (
    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    email TEXT UNIQUE NOT NULL,
    password_hash TEXT NOT NULL,
    name TEXT NOT NULL,
    role TEXT DEFAULT 'admin',
    created_at TIMESTAMP DEFAULT NOW()
);

-- Clientes de Plagora
CREATE TABLE clients (
    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    name TEXT NOT NULL,
    phone TEXT,
    email TEXT,
    notes TEXT,
    created_at TIMESTAMP DEFAULT NOW()
);

-- Configuración global de costos (editable por el admin)
CREATE TABLE cost_config (
    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    filament_price_per_kg NUMERIC(10,2) NOT NULL,   -- Precio del kg de filamento
    electricity_kwh_price NUMERIC(10,4) NOT NULL,   -- Precio del kWh
    printer_wattage NUMERIC(8,2) NOT NULL,           -- Watts de la impresora
    failure_rate_percent NUMERIC(5,2) DEFAULT 5.0,  -- % margen de error/falla
    depreciation_per_hour NUMERIC(10,4) DEFAULT 0,  -- Desgaste impresora por hora
    updated_at TIMESTAMP DEFAULT NOW()
);

-- Ventas (core del negocio)
CREATE TABLE sales (
    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    client_id UUID REFERENCES clients(id),
    user_id UUID REFERENCES users(id),
    -- Inputs de la calculadora
    filament_grams NUMERIC(8,2),           -- Gramos de filamento usados
    print_time_minutes INT,                -- Tiempo de impresión en minutos
    filament_cost NUMERIC(10,4),           -- Costo de filamento calculado
    electricity_cost NUMERIC(10,4),        -- Costo de electricidad calculado
    failure_cost NUMERIC(10,4),            -- Costo por margen de error
    depreciation_cost NUMERIC(10,4),       -- Desgaste de impresora
    total_production_cost NUMERIC(10,2),   -- Suma de todos los costos
    profit_margin_percent NUMERIC(5,2),    -- % de ganancia deseado
    suggested_price NUMERIC(10,2),         -- Precio sugerido por la calculadora
    -- Venta final
    final_price NUMERIC(10,2) NOT NULL,    -- Precio que el cliente paga
    profit NUMERIC(10,2),                  -- Ganancia real (final_price - total_cost)
    status TEXT DEFAULT 'pendiente',       -- pendiente, en_proceso, completado, cancelado
    payment_method TEXT,
    paid BOOLEAN DEFAULT false,
    material TEXT,                         -- PLA, ABS, PETG, Resina, etc.
    notes TEXT,
    created_at TIMESTAMP DEFAULT NOW()
);
```

